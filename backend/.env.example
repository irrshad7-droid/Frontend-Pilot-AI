# LLM Provider (gemini or openai)
LLM_PROVIDER=gemini

# Google Gemini API Key (required for gemini provider)
GOOGLE_API_KEY=

# OpenAI API Key (required for openai provider)
OPENAI_API_KEY=

# LLM Model (default: gemini-3.5-flash)
LLM_MODEL=gemini-3.5-flash

# Target app URL for the Explorer agent (default: http://localhost:5173)
TARGET_APP_URL=http://localhost:5173

# CORS origins (comma-separated, overrides defaults)
# Default: http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173,https://frontend-pilot-ai.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,https://frontend-pilot-ai.vercel.app

# Server port (default: 8000)
PORT=8000
